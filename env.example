# MongoDB connection string
MONGODB_URI=mongodb+srv://user:password@cluster.xxxxx.mongodb.net/friendlink

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-to-a-secure-password

# JWT secret for session tokens
JWT_SECRET=generate-a-random-secret-string-here

# GitHub configuration (optional - only needed to auto-push to repo)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=owner/repo-name
GITHUB_FILE_PATH=link.yml

# App URL for embed codes
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email SMTP configuration (optional - sends notification on new submissions)
EMAIL_USER=your-email@163.com
EMAIL_PASS=your-smtp-authorization-code
EMAIL_NAME=Your Site Name  # optional sender display name, defaults to EMAIL_USER
EMAIL_RECIPIENT=your-email@163.com
SMTP_SERVER=smtp.163.com
SMTP_PORT=465

# Dark mode schedule (optional - auto switch dark mode at specific times)
# NEXT_PUBLIC_DARK_MODE_START=18:00
# NEXT_PUBLIC_DARK_MODE_END=06:00
